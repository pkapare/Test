{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(npm publish *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./**/.credentials*)",
      "Read(./**/appsettings.*.json)",
      "Bash(cat ./.env)",
      "Bash(cat ./.env.*)",
      "Bash(cat ./secrets/**)",
      "Bash(cat ./**/.credentials*)",
      "Bash(cat ./**/appsettings.*.json)",
      "Bash(head ./.env*)",
      "Bash(tail ./.env*)",
      "Bash(less ./.env*)",
      "Bash(more ./.env*)",
      "Bash(grep * ./.env*)",
      "Bash(grep * ./secrets/**)",
      "Bash(sed * ./.env*)",
      "Bash(awk * ./.env*)",
      "Bash(strings ./.env*)",
      "Bash(base64 ./.env*)",
      "Bash(xxd ./.env*)",
      "Bash(cp ./.env*)",
      "Bash(tee ./.env*)",
      "Bash(vi ./.env*)",
      "Bash(vim ./.env*)",
      "Bash(nano ./.env*)",
      "Bash(dd if=./.env*)",
      "Bash(source ./.env*)",
      "Bash(. ./.env*)",
      "Bash(python* ./.env*)",
      "Bash(python* -c *open*.env*)",
      "Bash(xargs * ./.env*)",
      "Bash(env)",
      "Bash(printenv*)",
      "Bash(export -p)",
      "Bash(set)",
      "Bash(cat /run/secrets/*)",
      "Bash(cat /proc/*/environ)",
      "Read(/run/secrets/*)",
      "Read(/proc/*/environ)",
      "Bash(declare -x)",
      "Bash(declare -x *)",
      "Bash(compgen *)",
      "Bash(node -e *process.env*)",
      "Bash(node -p *process.env*)",
      "Bash(python* -c *os.environ*)"
    ],
    "disableBypassPermissionsMode": "disable"
  }
}
