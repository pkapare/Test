# =============================================================================
# Enterprise DevContainers — Centralized Constants
#
# Single source of truth for all configurable values.
# Sourced by: shell scripts, docker-compose (.env symlink), CI workflows.
#
# Usage (shell):   source config/constants.env
# Usage (compose): cp config/constants.env .env  (or symlink)
# Usage (CI):      env $(cat config/constants.env | grep -v '#' | xargs)
# =============================================================================

# ─── Registry ────────────────────────────────────────────────────────────────
REGISTRY=kapconreg.azurecr.io/devcontainers
ACR_NAME=kapconreg

# ─── Base Image ──────────────────────────────────────────────────────────────
BASE_IMAGE=node:20-slim

# ─── Tool Versions ──────────────────────────────────────────────────────────
GIT_DELTA_VERSION=0.18.2
RIPGREP_VERSION=14.1.1
LAZYGIT_VERSION=0.44.1
CODE_SERVER_VERSION=4.100.3
DOTNET_CHANNEL=10.0

# ─── Ports ───────────────────────────────────────────────────────────────────
PORT_SERVE_WEB=8229
PORT_CODE_SERVER=8228
PORT_SSH=2222
PORT_HEALTH=8080

# ─── Security ────────────────────────────────────────────────────────────────
SSH_PASSWORD=claude-dev
SSH_PASSWORD_RANDOMIZE=true
CODE_SERVER_PASSWORD=claude-dev
FIREWALL_PROFILE=strict
FIREWALL_REFRESH_CRON=0 */4 * * *

# ─── Container Resources ────────────────────────────────────────────────────
TMPFS_TMP_SIZE=256m
TMPFS_RUN_SIZE=64m
NODE_MAX_OLD_SPACE=4096

# ─── Docker Compose Host Port Mappings ───────────────────────────────────────
# Format: HOST_PORT_<SERVICE>_<PROTOCOL>=<port>
HOST_PORT_SERVEWEB_WEB=8301
HOST_PORT_CODESERVER_WEB=8302
HOST_PORT_JETBRAINS_SSH=2201
HOST_PORT_UNIVERSAL_WEB=8304
HOST_PORT_UNIVERSAL_SSH=2204
HOST_PORT_LOB_DOTNET_WEB=8305
HOST_PORT_LOB_DOTNET_SSH=2205
HOST_PORT_LOB_NODEJS_WEB=8306
HOST_PORT_LOB_NODEJS_SSH=2206
HOST_PORT_PROJECT_ONE_WEB=8311
HOST_PORT_PROJECT_ONE_SSH=2211
HOST_PORT_PROJECT_TWO_WEB=8312
HOST_PORT_PROJECT_TWO_SSH=2212
HOST_PORT_PROJECT_THREE_WEB=8313
HOST_PORT_PROJECT_THREE_SSH=2213

# ─── CI/CD ───────────────────────────────────────────────────────────────────
CI_PLATFORMS=linux/amd64,linux/arm64
